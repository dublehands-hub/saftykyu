{
  "expo": {
    "name": "환경안전 도우미",
    "slug": "safty",
    "owner": "mastergwang",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "safty",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a2744"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mastergwang.safty"
    },
    "android": {
      "package": "com.mastergwang.safty"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      ["expo-router", { "origin": "https://replit.com/" }],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "여기에_복사한_ID_넣기"
      }
    }
  }
}
